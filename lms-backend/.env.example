# Copy ini jadi .env dan isi nilainya

# PostgreSQL connection string dari Railway/Neon/Supabase
DATABASE_URL=host=localhost user=postgres password=postgres dbname=gonzaga_lms port=5432 sslmode=disable

# JWT secret - ganti dengan string random panjang
JWT_SECRET=ganti-dengan-secret-random-yang-panjang

# Port (Railway otomatis isi ini)
PORT=8080
